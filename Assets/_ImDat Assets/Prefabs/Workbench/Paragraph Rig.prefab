  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "JH: AASAS. Well, you asked me a question that I now have no interesting
    answer. The answer is I have no feelings about it, but I do do recognize this,
    that while we\u2019re in the process of reinventing Nvidia, which it is always
    really central to what we\u2019re doing at the office, we\u2019re trying to reinvent
    Nvidia so that we could be ahead of the puck so that we could be where the industry
    will go and we want to solve problems that are hard and contribute to the industry.
    But very importantly now, not only have we created a computing platform, we reinvented
    our company, we\u2019re much more of a data center scale company, and we offer
    technology that is for the very first time wholly integrated to work together,
    but disintegrated so that the whole ecosystem could work with it.\u200B"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
